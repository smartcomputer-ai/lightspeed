{
  "_comment": "Example BRIDGE_CONFIG file. Copy to bridge.config.json, set BRIDGE_CONFIG=bridge.config.json in .env, and edit. JSON has no comments, so see README 'Access control and bindings' for field docs. Env vars (TELEGRAM_*, WHATSAPP_*) override the matching values here.",

  "telegram": {
    "allowFrom": [],
    "controlAllowFrom": ["@lukas"]
  },
  "whatsapp": {
    "allowFrom": [],
    "controlAllowFrom": ["41790000000@s.whatsapp.net"]
  },

  "bindings": [
    {
      "id": "personal-chat",
      "match": { "channel": ["telegram", "whatsapp"], "scope": "direct" },
      "profile": "personal",
      "sessionKey": "lukas",
      "pairing": { "codeEnv": "PERSONAL_PAIRING_CODE" }
    },
    {
      "id": "eng-room",
      "match": { "channel": "telegram", "chatId": "-1001234567890", "scope": "group" },
      "profile": {
        "kind": "inline",
        "profile": {
          "config": {
            "tools": { "messaging": true, "webSearch": true }
          },
          "mounts": [
            {
              "mountPath": "/playbook",
              "source": { "type": "snapshot", "snapshotRef": "snap_support_v3" },
              "access": "readOnly"
            }
          ],
          "mcp": [],
          "environments": []
        }
      },
      "sessionKey": "eng-support-room",
      "pairing": { "code": "demo-room-code" }
    },
    {
      "id": "support-whatsapp",
      "match": { "channel": "whatsapp", "scope": "direct" },
      "profile": { "kind": "named", "profileId": "support" },
      "pairing": { "codeEnv": "SUPPORT_PAIRING_CODE" }
    },
    {
      "match": { "channel": "*" }
    }
  ]
}
