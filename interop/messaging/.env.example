LIGHTSPEED_API_URL=http://127.0.0.1:18080/rpc
BRIDGE_STATE_PATH=.bridge-state.json

# Inbound batching (defaults shown).
#BRIDGE_DEBOUNCE_MS=500
#BRIDGE_TURN_MAX_BATCH=10
#BRIDGE_TURN_MAX_WAIT_MS=2500
# Room-event batching toward context/append (defaults shown).
#BRIDGE_ROOM_FLUSH_MS=30000
#BRIDGE_ROOM_FLUSH_MAX=20
#BRIDGE_ROOM_BUDGET=50

# Telegram starts when TELEGRAM_BOT_TOKEN is set.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
# Senders allowed to run /activation, /new, /status (user ids). With this
# empty, direct chats are trusted and group members are not.
TELEGRAM_ALLOW_FROM=
# Default activation for groups: mention | always | silent.
TELEGRAM_GROUP_ACTIVATION=mention
# Reply-quote behavior in groups: off | first | all. DMs never quote.
TELEGRAM_REPLY_TO_MODE=first
TELEGRAM_TRIGGER_PREFIXES=/ask,/lightspeed
TELEGRAM_MENTION_NAMES=

# WhatsApp starts only when WHATSAPP_ENABLED=true.
WHATSAPP_ENABLED=false
WHATSAPP_AUTH_DIR=.whatsapp-auth
WHATSAPP_ALLOWED_JIDS=
WHATSAPP_ALLOW_FROM=
WHATSAPP_GROUP_ACTIVATION=mention
WHATSAPP_REPLY_TO_MODE=first
WHATSAPP_TRIGGER_PREFIXES=/ask,/lightspeed
WHATSAPP_MENTION_NAMES=
WHATSAPP_PRINT_QR=true
