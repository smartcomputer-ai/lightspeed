{
  "name": "@lightspeed/configurator-mcp",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Streamable HTTP MCP facade over the universe-scoped Lightspeed API.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lightspeed-configurator-mcp": "./dist/bin.js"
  },
  "files": [
    "dist",
    "src/generated/tools.ts",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "generate": "node scripts/generate-tools.mjs",
    "check:generated": "npm run generate && git diff --exit-code -- src/generated/tools.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "check": "npm run check:generated && npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@lightspeed/agent-client": "file:../ts-client",
    "@modelcontextprotocol/sdk": "1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "express": "^5.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
