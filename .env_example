OPENAI_API_KEY=set_your_openai_api_key_here
ANTHROPIC_API_KEY=set_your_anthropic_api_key_here

# Gateway auth mode: single (default), trusted-header, or api-key.
# See README "Multi-Tenancy".
#LIGHTSPEED_AUTH_MODE=single
#LIGHTSPEED_UNIVERSE_AUTO_CREATE=false
# Client-side credentials for the CLI/bridge against multi-tenant gateways:
#LIGHTSPEED_API_KEY=lsk_...
#LIGHTSPEED_UNIVERSE=00000000-0000-0000-0000-000000000001
